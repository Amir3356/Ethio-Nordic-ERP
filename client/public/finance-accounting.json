  "system_architecture": {
    "layers": [
      { "layer": "Presentation", "responsibility": "Ledger entry, AP/AR, reporting UI", "technology": "React + TypeScript" },
      { "layer": "Posting Engine", "responsibility": "Double-entry validation & automated sub-ledger postings", "technology": "Laravel Service Layer" },
      { "layer": "Integration Listeners", "responsibility": "Consumes events from Sales, Procurement, HR, Inventory", "technology": "Laravel Event Listeners / Queues" },
      { "layer": "Reporting Engine", "responsibility": "Financial statement computation & export", "technology": "Laravel + Excel/PDF export libraries" },
      { "layer": "Persistence", "responsibility": "Chart of accounts, journals, AP/AR, assets", "technology": "PostgreSQL" }
    ],
    "database_entities": [
      { "table": "chart_of_accounts", "purpose": "Hierarchical account structure" },
      { "table": "journal_entries", "purpose": "Header record for each double-entry posting" },
      { "table": "journal_lines", "purpose": "Individual debit/credit lines linked to accounts" },
      { "table": "ap_invoices", "purpose": "Supplier invoices and payment status" },
      { "table": "ar_invoices", "purpose": "Customer invoices and collection status" },
      { "table": "bank_transactions", "purpose": "Bank statement lines and reconciliation status" },
      { "table": "budgets", "purpose": "Cost-center budget allocations by period" },
      { "table": "fixed_assets", "purpose": "Asset register with depreciation schedules" },
      { "table": "tax_records", "purpose": "VAT/withholding tax computations by period" }
    ]
  }
